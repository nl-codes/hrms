@model ApplicationsReviewIndexViewModel

@{
    ViewData["Title"] = "Application Review";
}

<div class="dashboard-card">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
        <div>
            <h1 class="h3 mb-1">Hiring Review</h1>
            <p class="text-muted mb-0">Review applications, screen candidates, and hire applicants.</p>
        </div>
    </div>

    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <a class="nav-link @(Model.ActiveTab == "all" ? "active" : "")" asp-action="Index" asp-route-tab="all">All
                (@Model.AllCount)</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.ActiveTab == "screened" ? "active" : "")" asp-action="Index"
                   asp-route-tab="screened">Screened (@Model.ScreenedCount)</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.ActiveTab == "rejected" ? "active" : "")" asp-action="Index"
                   asp-route-tab="rejected">Rejected (@Model.RejectedCount)</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.ActiveTab == "hired" ? "active" : "")" asp-action="Index"
                   asp-route-tab="hired">Hired (@Model.HiredCount)</a>
            </li>
        </ul>

        @if (!Model.Applications.Any())
        {
            <div class="alert alert-info mb-0">No applications found for this tab.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Applicant</th>
                            <th>Job</th>
                            <th>Highest Degree</th>
                            <th>Experience</th>
                            <th>Status</th>
                            <th>Applied</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model.Applications)
                        {
                            <tr>
                                <td>#@app.Id</td>
                                <td>@app.ApplicantEmail</td>
                                <td>@app.JobTitle</td>
                                <td>@app.HighestDegree</td>
                                <td>@app.ApplicantExperienceYears years</td>
                                <td>
                                    <partial name="_ApplicationStatusBadge" model="app.Status" />
                                    @if (app.Status == ApplicationStatus.Rejected &&
                                                            !string.IsNullOrWhiteSpace(app.RejectionReason))
                                    {
                                        <div class="small text-danger mt-1">Rejected: @app.RejectionReason</div>
                                    }
                                    else if (app.Status == ApplicationStatus.Screened)
                                    {
                                        <div class="small text-muted mt-1">Passed automated screening.</div>
                                    }
                                </td>
                                <td>@app.AppliedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Details"
                                       asp-route-id="@app.Id">Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
