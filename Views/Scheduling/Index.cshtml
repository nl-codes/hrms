@model ScheduleIndexViewModel

@{
    ViewData["Title"] = Model.IsProductionManagerView ? "Weekly Schedules" : "My Schedules";
}

<div class="dashboard-card">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
        <div>
            <h1 class="h3 mb-1">@(Model.IsProductionManagerView ? "Weekly Schedules" : "My Schedules")</h1>
            <p class="text-muted mb-0">
                @(Model.IsProductionManagerView
                    ? "Review employee schedules by week."
                    : "Manage your schedules week by week and track completion.")
            </p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string success)
    {
        <div class="alert alert-success">@success</div>
    }

    @if (TempData["ErrorMessage"] is string error)
    {
        <div class="alert alert-warning">@error</div>
    }

    @if (Model.IsProductionManagerView)
    {
        <form asp-action="Index" method="get" class="row g-3 align-items-end mb-4">
            <div class="col-md-4">
                <label class="form-label" for="weekStart">Filter by Week (Monday)</label>
                <select class="form-select" id="weekStart" name="weekStart" onchange="this.form.submit()">
                    @if (!Model.AvailableWeeks.Any())
                    {
                        <option value="">No schedules available</option>
                    }
                    else
                    {
                        @foreach (var week in Model.AvailableWeeks)
                        {
                            <option value="@week.ToString("yyyy-MM-dd")" selected="@(Model.SelectedWeekStartUtc == week)">
                                @week.ToString("yyyy-MM-dd")
                            </option>
                        }
                    }
                </select>
            </div>
        </form>

        @if (!Model.ProductionWeekSchedules.Any())
        {
            <div class="alert alert-info mb-0">No employee schedules found for this week.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Email</th>
                            <th>Total Hours</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.ProductionWeekSchedules)
                        {
                            <tr>
                                <td>@item.EmployeeName</td>
                                <td>@item.EmployeeEmail</td>
                                <td>@item.TotalHours</td>
                                <td>
                                    <span
                                    class="badge @(item.Status == "Complete" ? "text-bg-success" : "text-bg-warning")">@item.Status</span>
                                </td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit"
                                           asp-route-weekStart="@Model.SelectedWeekStartUtc?.ToString("yyyy-MM-dd")"
                                           asp-route-employeeUserId="@item.EmployeeUserId">
                                        View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
    else
    {
        <form asp-action="ScheduleNewWeek" method="post" class="row g-3 align-items-end mb-4">
            @Html.AntiForgeryToken()
            <div class="col-md-4">
                <label class="form-label" for="weekStartUtc">Schedule New Week (Monday)</label>
                <input id="weekStartUtc" name="weekStartUtc" type="date" class="form-control"
                       min="@Model.CurrentMondayUtc.AddDays(7).ToString("yyyy-MM-dd")" required />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary">Schedule New Week</button>
            </div>
        </form>

        @if (!Model.ScheduledWeeks.Any())
        {
            <div class="alert alert-info mb-0">No scheduled weeks yet.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Week Start (Monday)</th>
                            <th>Total Hours</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var week in Model.ScheduledWeeks)
                        {
                            <tr>
                                <td>@week.WeekStartUtc.ToString("yyyy-MM-dd")</td>
                                <td>@week.TotalHours</td>
                                <td>
                                    <span
                                    class="badge @(week.Status == "Complete" ? "text-bg-success" : "text-bg-warning")">@week.Status</span>
                                </td>
                                <td class="text-end">
                                    <a class="btn btn-sm @(week.CanEdit ? "btn-outline-primary" : "btn-outline-secondary")"
                                           asp-action="Edit" asp-route-weekStart="@week.WeekStartUtc.ToString("yyyy-MM-dd")">
                                        @(week.CanEdit ? "Edit" : "View")
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>
