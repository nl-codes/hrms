@{
    ViewData["Title"] = "Access Denied";
}

<div class="dashboard-card mx-auto" style="max-width: 600px;">
    <div class="text-center mb-4">
        <h1 class="h2 mb-2">Access Denied</h1>
        <p class="text-muted mb-4">You do not have permission to access this page.</p>
    </div>

    <div class="alert alert-warning mb-4">
        <strong>Note:</strong> Your current role does not have access to this resource. If you believe this is an error,
        please contact an administrator.
    </div>

    <div class="d-flex gap-2 justify-content-center">
        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Go to Dashboard</a>
        <a class="btn btn-outline-secondary" href="javascript:history.back()">Go Back</a>
    </div>
</div>
