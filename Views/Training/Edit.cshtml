@model TrainingSessionEditViewModel

@{
    ViewData["Title"] = "Edit Training Session";
}

<div class="dashboard-card mx-auto" style="max-width: 900px;">
    <h1 class="h3 mb-3">Edit Training Session</h1>

    <form asp-action="Edit" method="post" class="row g-3">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="col-12">
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="col-12">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="SessionDateUtc" class="form-label"></label>
            <input asp-for="SessionDateUtc" type="datetime-local" class="form-control" />
            <span asp-validation-for="SessionDateUtc" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="MaxEnrollment" class="form-label"></label>
            <input asp-for="MaxEnrollment" class="form-control" min="1" />
            <span asp-validation-for="MaxEnrollment" class="text-danger"></span>
        </div>

        <div class="col-md-3 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Active Session</label>
            </div>
        </div>

        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-outline-secondary" asp-action="InstructorIndex">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
