@model IReadOnlyList<TrainingInstructorListItemViewModel>

@{
    ViewData["Title"] = "Training Console";
    var isInstructor = User.IsInRole("Instructor");
}

<div class="dashboard-card">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
        <div>
            <h1 class="h3 mb-1">Training Console</h1>
            <p class="text-muted mb-0">Manage training sessions and track attendance.</p>
        </div>
        @if (isInstructor)
        {
            <a class="btn btn-primary" asp-action="Create">Create Session</a>
        }
    </div>

    @if (TempData["SuccessMessage"] is string success)
    {
        <div class="alert alert-success">@success</div>
    }

    @if (TempData["ErrorMessage"] is string error)
    {
        <div class="alert alert-warning">@error</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info mb-0">No training sessions found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Instructor</th>
                        <th>Date</th>
                        <th>Enrollment</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var session in Model)
                    {
                        <tr>
                            <td>@session.Title</td>
                            <td>@session.InstructorName</td>
                            <td>@session.SessionDateUtc.ToString("yyyy-MM-dd HH:mm") UTC</td>
                            <td>@session.EnrollmentCount / @session.MaxEnrollment</td>
                            <td>
                                <span class="badge @(session.IsActive ? "text-bg-success" : "text-bg-secondary")">
                                    @(session.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2 flex-wrap">
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Details"
                                       asp-route-id="@session.Id">Details</a>
                                    @if (isInstructor)
                                    {
                                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit"
                                           asp-route-id="@session.Id">Edit</a>
                                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete"
                                           asp-route-id="@session.Id">Delete</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
