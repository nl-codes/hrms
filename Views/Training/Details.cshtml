@model TrainingDetailsViewModel

@{
    ViewData["Title"] = "Training Session Details";
}

<div class="dashboard-card">
    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
        <div>
            <h1 class="h3 mb-1">@Model.Title</h1>
            <div class="text-muted">Instructor: @Model.InstructorName</div>
        </div>
        <span class="badge @(Model.IsActive ? "text-bg-success" : "text-bg-secondary")">@(Model.IsActive ? "Active" :
                        "Inactive")</span>
        </div>

        @if (TempData["SuccessMessage"] is string success)
        {
            <div class="alert alert-success">@success</div>
        }

        <dl class="row mb-4">
            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">Date</dt>
            <dd class="col-sm-9">@Model.SessionDateUtc.ToString("yyyy-MM-dd HH:mm") UTC</dd>

            <dt class="col-sm-3">Capacity</dt>
            <dd class="col-sm-9">@Model.Enrollments.Count / @Model.MaxEnrollment</dd>
        </dl>

        <h2 class="h5 mb-3">Enrolled Employees</h2>
        @if (!Model.Enrollments.Any())
        {
            <div class="alert alert-info mb-0">No employees are enrolled yet.</div>
        }
        else if (Model.CanManageAttendance)
        {
            <form asp-action="UpdateAttendance" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Status</th>
                                <th class="text-end">Attendance</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < Model.Enrollments.Count; i++)
                            {
                                var enrollment = Model.Enrollments[i];
                                <tr>
                                    <td>@enrollment.EmployeeName</td>
                                    <td>@enrollment.EmployeeEmail</td>
                                    <td>
                                        <span class="badge @(enrollment.Status == EnrollmentStatus.Completed ? "text-bg-success" : enrollment.Status == EnrollmentStatus.Absent ? "text-bg-danger" : "text-bg-info")">
                                            @enrollment.Status
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <input type="hidden" asp-for="AttendanceUpdates[i].EmployeeUserId" />
                                        <select asp-for="AttendanceUpdates[i].Status" class="form-select form-select-sm d-inline-block" style="min-width: 150px;">
                                            <option value="Completed">Completed</option>
                                            <option value="Absent">Absent</option>
                                            <option value="Enrolled">Enrolled</option>
                                        </select>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-3 d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary">Update All Attendance</button>
                </div>
            </form>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var enrollment in Model.Enrollments)
                        {
                            <tr>
                                <td>@enrollment.EmployeeName</td>
                                <td>@enrollment.EmployeeEmail</td>
                                <td>
                                    <span class="badge @(enrollment.Status == EnrollmentStatus.Completed ? "text-bg-success" : enrollment.Status == EnrollmentStatus.Absent ? "text-bg-danger" : "text-bg-info")">
                                        @enrollment.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="mt-3">
            <a class="btn btn-outline-secondary" asp-action="InstructorIndex">Back</a>
        </div>
    </div>
