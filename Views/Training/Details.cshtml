@model TrainingDetailsViewModel

@{
    ViewData["Title"] = "Training Session Details";
}

<div class="dashboard-card">
    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
        <div>
            <h1 class="h3 mb-1">@Model.Title</h1>
            <div class="text-muted">Instructor: @Model.InstructorName</div>
        </div>
        <span class="badge @(Model.IsActive ? "text-bg-success" : "text-bg-secondary")">@(Model.IsActive ? "Active" :
                        "Inactive")</span>
        </div>

        @if (TempData["SuccessMessage"] is string success)
        {
            <div class="alert alert-success">@success</div>
        }

        <dl class="row mb-4">
            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">Date</dt>
            <dd class="col-sm-9">@Model.SessionDateUtc.ToString("yyyy-MM-dd HH:mm") UTC</dd>

            <dt class="col-sm-3">Capacity</dt>
            <dd class="col-sm-9">@Model.Enrollments.Count / @Model.MaxEnrollment</dd>
        </dl>

        <h2 class="h5 mb-3">Enrolled Employees</h2>
        @if (!Model.Enrollments.Any())
        {
            <div class="alert alert-info mb-0">No employees are enrolled yet.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Status</th>
                            @if (Model.CanManageAttendance)
                            {
                                <th class="text-end">Attendance</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var enrollment in Model.Enrollments)
                        {
                            <tr>
                                <td>@enrollment.EmployeeName</td>
                                <td>@enrollment.EmployeeEmail</td>
                                <td>
                                    <span
                                        class="badge @(enrollment.Status == EnrollmentStatus.Completed ? "text-bg-success" : enrollment.Status == EnrollmentStatus.Absent ? "text-bg-danger" : "text-bg-info")">
                                        @enrollment.Status
                                    </span>
                                </td>
                                @if (Model.CanManageAttendance)
                                {
                                    <td class="text-end">
                                        <form asp-action="UpdateEnrollmentStatus" method="post"
                                              class="d-inline-flex gap-2 align-items-center">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="sessionId" value="@Model.Id" />
                                            <input type="hidden" name="employeeUserId" value="@enrollment.EmployeeUserId" />
                                            <select name="status" class="form-select form-select-sm" style="min-width: 150px;">
                                                <option value="Completed" selected="@(enrollment.Status == EnrollmentStatus.Completed)">
                                                    Completed</option>
                                                    <option value="Absent" selected="@(enrollment.Status == EnrollmentStatus.Absent)">Absent
                                                    </option>
                                                    <option value="Enrolled" selected="@(enrollment.Status == EnrollmentStatus.Enrolled)">
                                                        Enrolled</option>
                                                    </select>
                                                    <button type="submit" class="btn btn-sm btn-primary">Update</button>
                                                </form>
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <div class="mt-3">
                    <a class="btn btn-outline-secondary" asp-action="InstructorIndex">Back</a>
                </div>
            </div>
