@model IEnumerable<HRMS.Models.JobPosting>

@{
    ViewData["Title"] = "Job Postings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Job Postings</h1>
        <p class="text-muted mb-0">Manage open roles and applicant screening criteria.</p>
    </div>
    @if (User.IsInRole("HiringManager"))
    {
        <a class="btn btn-primary" asp-action="Create">Create Posting</a>
    }
</div>

<div class="table-responsive dashboard-card p-0">
    <table class="table align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Title</th>
                <th>Experience</th>
                <th>Openings</th>
                <th>Skills</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var job in Model)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@job.Title</div>
                        <div class="small text-muted">Posted @job.CreatedAtUtc.ToString("yyyy-MM-dd")</div>
                    </td>
                    <td>@job.RequiredExperienceYears years</td>
                    <td>@job.OpenPositions</td>
                    <td>@job.RequiredSkillsCsv</td>
                    <td>
                        <span class="badge @(job.IsActive ? "text-bg-success" : "text-bg-secondary")">@(job.IsActive ?
                                                                    "Active" : "Closed")</span>
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm" role="group">
                                <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@job.Id">Details</a>
                                @if (User.IsInRole("HiringManager"))
                                {
                                    <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@job.Id">Edit</a>
                                    <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@job.Id">Delete</a>
                                }
                                else if (User.IsInRole("Applicant"))
                                {
                                    if (job.IsActive)
                                    {
                                        <a class="btn btn-primary" asp-controller="Applications" asp-action="Apply"
                                           asp-route-id="@job.Id">Apply</a>
                                    }
                                    else
                                    {
                                        <a class="btn btn-secondary disabled" aria-disabled="true">Hiring Completed</a>
                                    }
                                }
                                else
                                {
                                    if (job.IsActive)
                                    {
                                        <a class="btn btn-primary" asp-controller="Applications" asp-action="Apply"
                                           asp-route-id="@job.Id">Apply</a>
                                    }
                                    else
                                    {
                                        <a class="btn btn-secondary disabled" aria-disabled="true">Hiring Completed</a>
                                    }
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
