@model IReadOnlyList<InstructorListItemViewModel>

@{
    ViewData["Title"] = "Instructor Management";
}

<div class="dashboard-card">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
        <div>
            <h1 class="h3 mb-1">Instructor Management</h1>
            <p class="text-muted mb-0">Manage instructor accounts created by Hiring Managers.</p>
        </div>
        <a class="btn btn-primary" asp-action="Create">Create Instructor</a>
    </div>

    @if (TempData["SuccessMessage"] is string success)
    {
        <div class="alert alert-success">@success</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info mb-0">No instructors found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Domain</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var instructor in Model)
                    {
                        <tr>
                            <td>@instructor.FullName</td>
                            <td>@instructor.Email</td>
                            <td>@instructor.Domain</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
