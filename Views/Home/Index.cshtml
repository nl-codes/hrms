@{
    ViewData["Title"] = "Dashboard";

    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var isHiringManager = User.IsInRole("HiringManager");
    var isApplicant = User.IsInRole("Applicant");
    var isEmployee = User.IsInRole("Employee");
    var isInstructor = User.IsInRole("Instructor");
    var isProductionManager = User.IsInRole("ProductionManager");
}

<div class="dashboard-shell">
    <div class="dashboard-hero">
        <div>
            <p class="eyebrow">We Build Stuff</p>
            <h1 class="display-5 fw-bold">Human Resource System</h1>
            <p class="lead mb-0">Centralized hiring, training, and scheduling for the WBS workforce.</p>
        </div>
        <div class="dashboard-meta">
            <span class="badge rounded-pill bg-light text-dark">HRMS</span>
            <span class="badge rounded-pill bg-dark">MySQL hrms</span>
        </div>
    </div>

    <div class="row g-4 mt-1">
        @if (isHiringManager)
        {
            <div class="col-lg-4 col-md-6">
                <div class="dashboard-card h-100">
                    <h2>Hiring Manager</h2>
                    <p>Manage openings, screen applicants, promote employees, and track training.</p>
                    <div class="d-grid gap-2">
                        <a class="btn btn-primary" asp-controller="JobPostings" asp-action="Index">Manage Jobs</a>
                        <a class="btn btn-outline-primary" asp-controller="JobPostings" asp-action="Create">Create Job
                            Posting</a>
                            <a class="btn btn-outline-dark" asp-controller="Applications" asp-action="Index">Review
                                Applications</a>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-6">
                        <div class="dashboard-card h-100">
                            <h2>Instructor Management</h2>
                            <p>Create and manage instructor accounts with role-based access control.</p>
                            <div class="d-grid gap-2">
                                <a class="btn btn-primary" asp-controller="Instructor" asp-action="Index">Manage Instructors</a>
                            </div>
                        </div>
                    </div>
                }

                @if (isApplicant)
                {
                    <div class="col-lg-4 col-md-6">
                        <div class="dashboard-card h-100">
                            <h2>Applicant</h2>
                            <p>Review open roles and submit a profile for automated screening.</p>
                            <div class="d-grid gap-2">
                                <a class="btn btn-primary" asp-controller="JobPostings" asp-action="Index">Browse Jobs</a>
                                <a class="btn btn-outline-secondary" asp-controller="Applications" asp-action="MyApplications">My
                                    Applications</a>
                                </div>
                            </div>
                        </div>
                    }

                    @if (isEmployee)
                    {
                        <div class="col-lg-4 col-md-6">
                            <div class="dashboard-card h-100">
                                <h2>Employee</h2>
                                <p>Pick shifts, review weekly hours, and stay at the 6/36 schedule target.</p>
                                <div class="d-grid gap-2">
                                    <a class="btn btn-primary" asp-controller="Scheduling" asp-action="Index">My Schedule</a>
                                </div>
                            </div>
                        </div>
                    }

                    @if (isInstructor)
                    {
                        <div class="col-lg-4 col-md-6">
                            <div class="dashboard-card h-100">
                                <h2>Instructor</h2>
                                <p>Mark training completion and keep employee progress current.</p>
                                <div class="d-grid gap-2">
                                    <a class="btn btn-primary" href="#">Training Console</a>
                                </div>
                            </div>
                        </div>
                    }

                    @if (isProductionManager)
                    {
                        <div class="col-lg-4 col-md-6">
                            <div class="dashboard-card h-100">
                                <h2>Production Manager</h2>
                                <p>View work schedules without editing employee assignments.</p>
                                <div class="d-grid gap-2">
                                    <a class="btn btn-primary" asp-controller="Scheduling" asp-action="Index">View Schedule</a>
                                </div>
                            </div>
                        </div>
                    }

                    @if (!isAuthenticated)
                    {
                        <div class="col-lg-6 col-md-8">
                            <div class="dashboard-card h-100">
                                <h2>Public Access</h2>
                                <p>Use the shared login portal or browse the active job board.</p>
                                <div class="d-grid gap-2">
                                    <a class="btn btn-primary" asp-controller="Account" asp-action="Login">Login</a>
                                    <a class="btn btn-outline-primary" asp-controller="Account" asp-action="Register">Register</a>
                                    <a class="btn btn-outline-dark" asp-controller="JobPostings" asp-action="Index">Open Jobs</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
